{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "MIDI Studio",
  "version": "1.0.0",
  "identifier": "com.adamgrafica.midi-studio",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "MIDI Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}