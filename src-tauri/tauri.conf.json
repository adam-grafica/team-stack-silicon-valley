{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "MIDI Studio",
  "version": "1.0.0",
  "identifier": "com.adamgrafica.midi-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "url": "http://127.0.0.1:5173",
        "title": "MIDI Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": true,
        "transparent": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}