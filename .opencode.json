{
  "$schema": "https://opencode.ai/config.schema.json",
  "teamStack": "silicon-valley-v1.0",
  "version": "1.0.0",
  "agents": {
    "adam": {
      "model": "anthropic/claude-opus-4-5",
      "temperature": 0.2,
      "maxTokens": 8192,
      "system": "prompts/instructions/adam.md"
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-5",
      "temperature": 0.3,
      "maxTokens": 16384,
      "system": "prompts/instructions/atlas.md"
    },
    "forge": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.2,
      "maxTokens": 32768,
      "system": "prompts/instructions/forge.md"
    },
    "pixel": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.2,
      "maxTokens": 32768,
      "system": "prompts/instructions/pixel.md"
    },
    "sentinel": {
      "model": "anthropic/claude-sonnet-4-5",
      "temperature": 0.1,
      "maxTokens": 16384,
      "system": "prompts/instructions/sentinel.md"
    },
    "herald": {
      "model": "anthropic/claude-haiku-4-5",
      "temperature": 0.1,
      "maxTokens": 8192,
      "system": "prompts/instructions/herald.md"
    },
    "nexus": {
      "model": "deepseek/deepseek-chat",
      "temperature": 0.15,
      "maxTokens": 16384,
      "system": "prompts/instructions/nexus.md"
    },
    "cipher": {
      "model": "anthropic/claude-sonnet-4-5",
      "temperature": 0.1,
      "maxTokens": 16384,
      "system": "prompts/instructions/cipher.md"
    }
  },
  "orchestrator": "adam",
  "parallelExecution": true,
  "phaseValidation": "adam_only",
  "circuitBreaker": {
    "maxRetries": 3,
    "escalation": "adam",
    "maxBlockTimeMin": 15
  },
  "tokenLimits": {
    "planning": 50000,
    "execution": 32768,
    "validation": 16384
  },
  "mcp": {
    "enabled": true,
    "handlers": ["filesystem", "git", "github", "fetch"]
  }
}
