# Team Stack — .gitignore

# Environment
.env
.env.local
.env.*.local

# Rust
target/
Cargo.lock

# Node
node_modules/
dist/
.next/
build/

# Logs
*.log
logs/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/settings.json
.idea/
*.swp

# OpenCode session cache
.opencode/cache/
.opencode/sessions/

# Secrets (extra safety)
*.pem
*.key
secrets/
